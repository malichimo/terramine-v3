# Prevent Windows CRLF line ending corruption on TypeScript/JavaScript files
* text=auto
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
