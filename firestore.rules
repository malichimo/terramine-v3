// Firestore Security Rules for TerraMine Phase 2
// Copy this to Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns a resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId);
      
      // Users can create their own user document on signup
      allow create: if isOwner(userId);
      
      // Users can update their own data (balance, resources, etc.)
      allow update: if isOwner(userId);
      
      // No deletion allowed
      allow delete: if false;
    }
    
    // ============================================
    // PROPERTIES COLLECTION
    // ============================================
    match /properties/{propertyId} {
      // Anyone can read properties (to see on map)
      allow read: if true;
      
      // Only authenticated users can create properties
      allow create: if isSignedIn() && 
                      request.resource.data.ownerId == request.auth.uid;
      
      // Only property owner can update
      allow update: if isSignedIn() && 
                      resource.data.ownerId == request.auth.uid;
      
      // No deletion allowed
      allow delete: if false;
    }
    
    // ============================================
    // PROPERTY DETAILS COLLECTION (NEW)
    // ============================================
    match /propertyDetails/{propertyId} {
      // Anyone can read property details (to see levels, stats)
      allow read: if true;
      
      // Only authenticated users can create property details
      // (created when property is purchased)
      allow create: if isSignedIn();
      
      // Only the property owner can update details
      // (levels, custom name, daily activities, etc.)
      allow update: if isSignedIn() && 
                      exists(/databases/$(database)/documents/properties/$(propertyId)) &&
                      get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
      
      // No deletion allowed
      allow delete: if false;
    }
    
    // ============================================
    // CHECK-INS COLLECTION
    // ============================================
    match /checkIns/{checkInId} {
      // Users can read check-ins for properties they own
      // or check-ins they made
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.propertyOwnerId == request.auth.uid
      );
      
      // Users can create check-ins
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid;
      
      // No updates or deletes
      allow update, delete: if false;
    }
    
    // ============================================
    // DAILY ACTIVITIES COLLECTION (NEW)
    // ============================================
    match /dailyActivities/{activityId} {
      // Users can read their own daily activities
      allow read: if isSignedIn() && 
                    resource.data.userId == request.auth.uid;
      
      // Users can create daily activities
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid;
      
      // No updates or deletes
      allow update, delete: if false;
    }
    
    // ============================================
    // GAME RESULTS COLLECTION (NEW)
    // ============================================
    match /gameResults/{gameId} {
      // Users can read their own game results
      allow read: if isSignedIn() && 
                    resource.data.userId == request.auth.uid;
      
      // Users can create game results
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid;
      
      // No updates or deletes
      allow update, delete: if false;
    }
  }
}
